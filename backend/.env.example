# Server
PORT=5001
NODE_ENV=production

# Auth — change this to a long random string in production
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/secure-mail

# Frontend URL (your Vercel domain) — required for CORS
FRONTEND_URL=https://your-app.vercel.app

# Optional: disable cron cleanup jobs
# ENABLE_EMAIL_CLEANUP=false

# ML models need ~1–2 GB RAM. Auto-disabled on Railway. Set true only on servers with enough memory.
# AI_USE_ML_MODELS=false
